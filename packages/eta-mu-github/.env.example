# GitHub auth (use the installation token from actions/create-github-app-token when available)
GITHUB_TOKEN=

# Optional: eta-mu GitHub App metadata for docs / local runs
ETA_MU_APP_ID=
ETA_MU_APP_PRIVATE_KEY=
ETA_MU_APP_SLUG=eta-mu
ETA_MU_LOGIN=app/eta-mu
ETA_MU_REVIEW_CHECK_NAME=eta-mu-review-gate
ETA_MU_STATE_COMMENT_MARKER=<!-- eta-mu:state -->
ETA_MU_AUTOFIX_COMMENT_MARKER=<!-- eta-mu:autofix -->
ETA_MU_COMMIT_AUTHOR_NAME=eta-mu[bot]
ETA_MU_COMMIT_AUTHOR_EMAIL=eta-mu[bot]@users.noreply.github.com

# Pi model selection. If omitted, eta-mu will try the first authenticated pi model.
ETA_MU_MODEL_PROVIDER=
ETA_MU_MODEL_ID=

# Typical provider secrets pi can discover from the environment.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Behavior
ETA_MU_REVIEW_ACTORS=coderabbitai,app/coderabbitai
ETA_MU_MENTION_TOKENS=@eta-mu,@app/eta-mu
ETA_MU_IGNORE_LOGINS=github-actions[bot],coderabbitai[bot],app/eta-mu
