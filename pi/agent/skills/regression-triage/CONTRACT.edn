(skill-contract
  (name "regression-triage")
  (v "ημ.skill/regression-triage@0.1.0")

  (intent
    "Investigate regressions; identify introducing change; choose rollback vs fix-forward; add regression test.")

  (activation
    (priority 80)
    (explicit ["skill:regression-triage"])
    (triggers ["there was a regression" "this was a regression" "this regressed" "regression triage"]))

  (governance
    (touch-layer :mutable)
    (non-override [:mission :directives :safety :license :output-shape])
    (requires-user-approval false))

  (effects
    (writes true)
    (network false)
    (commits true))

  (protocol
    (workflow
      ["Confirm the regression is real on current HEAD (expected vs actual; env; version/commit)."
       "Locate introducing change (prefer git bisect with deterministic test command)."
       "Classify intent with uncertainty labels (side-effect vs incomplete/incorrect feature)."
       "Remediate: revert vs fix-forward."
       "MANDATORY: add a regression test covering the failed path."
       "Verify: smallest relevant suite first, then broader suite when feasible."
       "Record: intro commit, intent classification, remediation choice, and what the test protects."]))

  (output
    (must-include ["repro" "introducing-change" "regression-test" "verification"]))
)
