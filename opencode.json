{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "promethean-github":{
      "type":"remote",
      "url":"http://localhost:4320/github",
      "enabled": true
    },
    
  },
  "lsp": {
    "clojure": {
      "command": [
        "clojure-lsp",
        "listen"
      ],
      "extensions": [
        ".clj",
        ".cljs",
        ".cljc",
        ".edn"
      ]
    }
  },
  "tools":{
    "chrome*":true
  }
}
