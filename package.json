{
  "name": "eta-mu",
  "version": "0.1.0",
  "description": "Eta-mu monorepo - control plane, GitHub automation, truth/docs kernels, pi home, and Promethean runtime",
  "private": true,
  "license": "GPL-3.0-only",
  "type": "module",
  "workspaces": [
    "packages/*",
    "services/*",
    "shared/*"
  ],
  "scripts": {
    "dev": "concurrently \"pnpm --filter agentd dev\" \"pnpm --filter opencode-reactant dev\"",
    "build": "pnpm --filter opencode-reactant build && pnpm --filter agentd build",
    "typecheck": "echo \"skip typecheck\"",
    "docs:ts": "pnpm --filter @openhax/agentd doc",
    "docs:cljs": "clojure -X:codox",
    "docs": "pnpm docs:ts && pnpm docs:cljs",
    "coverage": "pnpm --filter agentd coverage",
    "start": "pnpm --filter agentd start",
    "clean": "pnpm --recursive clean",
    "install:all": "pnpm install && pnpm --recursive install"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "packageManager": "pnpm@8.15.0"
}
